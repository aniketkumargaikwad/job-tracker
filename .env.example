# ─── SMTP Configuration (Gmail: enable 2FA then create App Password) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# ─── PostgreSQL (Neon.tech free tier) ────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# ─── Job Search Preferences ─────────────────────────────────────────────────
TARGET_ROLES=.NET Developer,C# Developer,Angular Developer,Full Stack .NET Developer,Backend Developer
PREFERRED_COUNTRIES=India,UAE,UK,USA,Australia,Canada,Germany,Netherlands,Europe
EXCLUDED_COMPANIES=
PRIORITY_COMPANIES=
JOB_TITLE_BLACKLIST=Intern,Trainee,Fresher

# ─── Optional Free-tier API Keys (register – no credit card needed) ─────────
# Adzuna: https://developer.adzuna.com  (free 200 req/day)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Reed.co.uk: https://www.reed.co.uk/developers/jobseeker  (free)
REED_API_KEY=
# Jooble: https://jooble.org/api/about  (free)
JOOBLE_API_KEY=

# ─── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
PROFILE_WORK_AUTH=

# ─── Portal Credentials (for auto-apply – leave blank to skip) ──────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD=

# ─── Web Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000

# ─── Run without sending emails ─────────────────────────────────────────────
RUN_NO_EMAIL=true
