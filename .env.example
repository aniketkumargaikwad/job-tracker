# ─── SMTP Configuration (Gmail: enable 2FA then create App Password) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# ─── Job Search Preferences ─────────────────────────────────────────────────
TARGET_ROLES=.NET Developer,C# Developer,Angular Developer,Full Stack .NET Developer,Backend Developer
PREFERRED_COUNTRIES=India,UAE,UK,USA,Australia,Canada,Germany,Netherlands,Europe
EXCLUDED_COMPANIES=
PRIORITY_COMPANIES=
JOB_TITLE_BLACKLIST=Intern,Trainee,Fresher

# ─── Optional Free-tier API Keys (register – no credit card needed) ─────────
# Adzuna: https://developer.adzuna.com  (free 200 req/day)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Reed.co.uk: https://www.reed.co.uk/developers/jobseeker  (free)
REED_API_KEY=
# Jooble: https://jooble.org/api/about  (free)
JOOBLE_API_KEY=

# ─── User Profile (for auto-apply form filling) ─────────────────────────────
PROFILE_FULL_NAME=John Doe
PROFILE_EMAIL=john.doe@email.com
PROFILE_PHONE=+91-9876543210
PROFILE_LOCATION=Mumbai, India
PROFILE_EXPERIENCE_YEARS=5
PROFILE_CURRENT_TITLE=Senior .NET Developer
PROFILE_LINKEDIN=https://linkedin.com/in/johndoe
PROFILE_GITHUB=https://github.com/johndoe
PROFILE_RESUME_PATH=data/resume.pdf
PROFILE_COVER_LETTER_PATH=data/cover_letter.txt
PROFILE_SKILLS=C#,.NET Core,Angular,Microservices,Azure,SQL Server,Docker,Kubernetes
PROFILE_CURRENT_COMPANY=
PROFILE_CURRENT_SALARY=
PROFILE_EXPECTED_SALARY=
PROFILE_NOTICE_PERIOD=
PROFILE_WORK_AUTH=

# ─── Portal Credentials (for auto-apply – leave blank to skip) ──────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD=

# ─── Web Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000

# ─── Run without sending emails ─────────────────────────────────────────────
RUN_NO_EMAIL=true
